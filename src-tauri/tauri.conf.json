{
  "productName": "DIANA",
  "version": "0.1.0",
  "identifier": "com.diana.assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "D.I.A.N.A",
        "width": 380,
        "height": 570,
        "minWidth": 280,
        "minHeight": 400,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "x": 0,
        "y": 0,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxRDhCQzEzNkM0QzA2NTIKUldSU0JreHNFN3pZUWYvNExoZ1FmSXVsdU9uY2ZPQ09sZVpXaHVhL3JzVG5pVXZwYkJsMGNFUWYK",
      "endpoints": [
        "https://github.com/TryndamereSama/D.I.A.N.A_Project/releases/latest/download/latest.json"
      ]
    }
  }
}
